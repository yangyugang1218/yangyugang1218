<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>China Electricity Market | Yugang Yang</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:       #070d1a;
      --bg2:      #0d1b2a;
      --bg3:      #112240;
      --accent:   #00d4aa;
      --accent2:  #3b9eff;
      --gold:     #f0a500;
      --text:     #e0eaf5;
      --muted:    #8899aa;
      --border:   rgba(255,255,255,0.08);
      --card:     rgba(255,255,255,0.04);
      --radius:   8px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); font-size: 13px; line-height: 1.65; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ===== HEADER ===== */
    .elec-header {
      position: relative;
      background: linear-gradient(135deg, #070d1a 0%, #0d2545 60%, #071428 100%);
      padding: 3.5rem 2rem 3rem;
      text-align: center;
      overflow: hidden;
      border-bottom: 1px solid var(--border);
    }
    .elec-header::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0,212,170,.12) 0%, transparent 70%);
      pointer-events: none;
    }
    /* Animated grid lines */
    .grid-bg {
      position: absolute; inset: 0; pointer-events: none; opacity: .18;
      background-image: linear-gradient(rgba(0,212,170,.4) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(0,212,170,.4) 1px, transparent 1px);
      background-size: 48px 48px;
    }
    .back-link {
      display: inline-flex; align-items: center; gap: .4rem;
      font-size: .8rem; color: var(--muted); margin-bottom: 1.5rem;
      transition: color .2s;
    }
    .back-link:hover { color: var(--accent); text-decoration: none; }
    .elec-header h1 {
      font-size: 2.2rem; font-weight: 700; letter-spacing: -.5px;
      background: linear-gradient(90deg, #00d4aa, #3b9eff);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      margin-bottom: .5rem; position: relative;
    }
    .elec-header p { font-size: .9rem; color: var(--muted); position: relative; }
    .header-lang { position: absolute; top: 1.5rem; right: 1.5rem; display: flex; gap: .4rem; }
    .hl-btn {
      background: none; border: 1px solid var(--border); border-radius: 5px;
      padding: .25rem .65rem; font-size: .75rem; font-weight: 600; cursor: pointer;
      color: var(--muted); transition: all .2s;
    }
    .hl-btn.active { background: var(--accent); border-color: var(--accent); color: #000; }

    /* ===== STATS BAR ===== */
    .stats-bar {
      display: grid; grid-template-columns: repeat(5, 1fr);
      gap: 0; border-bottom: 1px solid var(--border);
    }
    .stat-card {
      padding: 1.25rem .75rem;
      text-align: center;
      border-right: 1px solid var(--border);
      position: relative; overflow: hidden;
    }
    .stat-card:last-child { border-right: none; }
    .stat-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }
    .stat-num {
      display: block; font-size: 1.7rem; font-weight: 700;
      color: var(--accent); line-height: 1; margin-bottom: .35rem;
      font-variant-numeric: tabular-nums;
    }
    .stat-label { font-size: .72rem; color: var(--muted); line-height: 1.4; }

    /* ===== SECTION ===== */
    .elec-section { max-width: 1100px; margin: 0 auto; padding: 2.5rem 2rem; }
    .elec-section + .elec-section { border-top: 1px solid var(--border); }
    .section-header { display: flex; align-items: center; gap: .75rem; margin-bottom: 1.5rem; }
    .section-icon { width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, var(--accent), var(--accent2)); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: .9rem; }
    .section-title { font-size: 1.1rem; font-weight: 700; color: var(--text); }
    .section-subtitle { font-size: .78rem; color: var(--muted); margin-top: .1rem; }

    /* ===== MAP ===== */
    .map-wrap {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden; position: relative;
    }
    .map-header { padding: .85rem 1.25rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .map-title { font-size: .85rem; font-weight: 600; color: var(--text); }
    .map-note { font-size: .72rem; color: var(--muted); }
    #china-map { width: 100%; height: 480px; }
    .map-legend { padding: .75rem 1.25rem; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 1.5rem; font-size: .75rem; color: var(--muted); }
    .legend-bar { display: flex; align-items: center; gap: .5rem; }
    .legend-gradient { width: 120px; height: 10px; border-radius: 3px; background: linear-gradient(90deg, #1a3a72, #1976d2, #00bcd4, #ffca28, #ef6c00); }
    .legend-labels { display: flex; justify-content: space-between; width: 120px; font-size: .68rem; color: var(--muted); margin-top: .15rem; }
    .map-disclaimer { padding: .5rem 1.25rem; background: rgba(240,165,0,.08); border-top: 1px solid rgba(240,165,0,.15); font-size: .72rem; color: var(--gold); }

    /* ===== PROVINCE TABLE ===== */
    .prov-tabs { display: flex; gap: .4rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .prov-tab {
      padding: .3rem .8rem; border-radius: 20px; font-size: .78rem; font-weight: 500;
      cursor: pointer; border: 1px solid var(--border); color: var(--muted);
      transition: all .2s; background: none;
    }
    .prov-tab.active { background: var(--accent); border-color: var(--accent); color: #000; font-weight: 600; }
    .prov-tab:hover:not(.active) { border-color: var(--accent); color: var(--accent); }

    .prov-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: .75rem; }
    .prov-card {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: var(--radius); padding: .9rem 1rem;
      transition: border-color .2s, transform .2s;
      position: relative; overflow: hidden;
    }
    .prov-card:hover { border-color: var(--accent); transform: translateY(-2px); }
    .prov-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    }
    .prov-card.status-formal::before { background: var(--accent); }
    .prov-card.status-trial::before { background: var(--gold); }
    .prov-card.status-building::before { background: var(--accent2); }
    .prov-name { font-size: .9rem; font-weight: 700; color: var(--text); margin-bottom: .3rem; }
    .prov-name-en { font-size: .72rem; color: var(--muted); }
    .prov-price {
      font-size: 1.3rem; font-weight: 700; margin: .4rem 0 .2rem;
      font-variant-numeric: tabular-nums;
    }
    .price-high   { color: #ef6c00; }
    .price-medium { color: var(--gold); }
    .price-low    { color: var(--accent); }
    .price-na     { color: var(--muted); font-size: .9rem; }
    .prov-meta { display: flex; align-items: center; justify-content: space-between; margin-top: .3rem; }
    .prov-unit { font-size: .7rem; color: var(--muted); }
    .status-badge {
      font-size: .65rem; font-weight: 700; padding: .15rem .45rem; border-radius: 3px;
      text-transform: uppercase; letter-spacing: .5px;
    }
    .badge-formal   { background: rgba(0,212,170,.15); color: var(--accent); }
    .badge-trial    { background: rgba(240,165,0,.15); color: var(--gold); }
    .badge-building { background: rgba(59,158,255,.15); color: var(--accent2); }
    .badge-na       { background: rgba(136,153,170,.1); color: var(--muted); }

    /* ===== TIMELINE ===== */
    .timeline-wrap { position: relative; padding-left: 1.5rem; }
    .timeline-wrap::before { content: ''; position: absolute; left: .4rem; top: 0; bottom: 0; width: 1px; background: var(--border); }
    .tl-item { position: relative; margin-bottom: 1.25rem; }
    .tl-dot {
      position: absolute; left: -1.5rem; top: .2rem;
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--bg); border: 2px solid var(--accent);
    }
    .tl-year { font-size: .72rem; font-weight: 700; color: var(--accent); margin-bottom: .2rem; }
    .tl-text { font-size: .84rem; color: var(--text); line-height: 1.5; }
    .tl-sub { font-size: .77rem; color: var(--muted); margin-top: .15rem; }

    /* ===== DOCS TABLE ===== */
    .docs-region { margin-bottom: 1.75rem; }
    .docs-region-title {
      font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .8px;
      color: var(--accent); margin-bottom: .65rem; padding-bottom: .35rem;
      border-bottom: 1px solid rgba(0,212,170,.2);
    }
    .docs-table { width: 100%; border-collapse: collapse; font-size: .82rem; }
    .docs-table tr { border-bottom: 1px solid var(--border); transition: background .15s; }
    .docs-table tr:last-child { border-bottom: none; }
    .docs-table tr:hover { background: var(--card); }
    .docs-table td { padding: .55rem .5rem; vertical-align: top; }
    .dt-prov { width: 60px; font-weight: 700; color: var(--text); white-space: nowrap; }
    .dt-doc { color: var(--muted); }
    .dt-doc em { color: var(--text); font-style: normal; }
    .dt-link { text-align: right; white-space: nowrap; }
    .dt-link a {
      font-size: .72rem; font-weight: 600; color: var(--accent);
      border: 1px solid rgba(0,212,170,.4); padding: .18rem .5rem;
      border-radius: 4px; transition: background .2s, color .2s;
    }
    .dt-link a:hover { background: var(--accent); color: #000; text-decoration: none; }

    /* ===== FOOTER ===== */
    .elec-footer {
      text-align: center; padding: 2rem; font-size: .75rem; color: var(--muted);
      border-top: 1px solid var(--border);
    }
    .elec-footer a { color: var(--muted); }
    .elec-footer a:hover { color: var(--accent); }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .stats-bar { grid-template-columns: repeat(3, 1fr); }
      .stat-card:nth-child(3) { border-right: none; }
      .elec-header h1 { font-size: 1.6rem; }
      #china-map { height: 320px; }
      .prov-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 480px) {
      .stats-bar { grid-template-columns: repeat(2, 1fr); }
      .prov-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>

<!-- HEADER -->
<header class="elec-header">
  <div class="grid-bg"></div>
  <div class="header-lang">
    <button class="hl-btn active" id="hbtn-en" onclick="setLang('en')">EN</button>
    <button class="hl-btn" id="hbtn-zh" onclick="setLang('zh')">中文</button>
  </div>
  <a href="index.html" class="back-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
    <span data-en="Back to Profile" data-zh="返回主页">Back to Profile</span>
  </a>
  <h1 data-en="China Electricity Market" data-zh="中国电力市场">China Electricity Market</h1>
  <p data-en="Provincial spot market prices · Policy documents · Reform timeline" data-zh="各省现货市场电价 · 政策文件 · 改革历程">Provincial spot market prices · Policy documents · Reform timeline</p>
</header>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="stat-card">
    <span class="stat-num" id="cnt-prov">21</span>
    <span class="stat-label" data-en="Spot Market Provinces" data-zh="现货市场省份">Spot Market Provinces</span>
  </div>
  <div class="stat-card">
    <span class="stat-num">2015</span>
    <span class="stat-label" data-en="Reform Launch Year" data-zh="改革启动年份">Reform Launch Year</span>
  </div>
  <div class="stat-card">
    <span class="stat-num">No.9</span>
    <span class="stat-label" data-en="Landmark Document" data-zh="改革纲领文件">Landmark Document</span>
  </div>
  <div class="stat-card">
    <span class="stat-num">3</span>
    <span class="stat-label" data-en="Exchange Centers" data-zh="区域交易中心">Exchange Centers</span>
  </div>
  <div class="stat-card">
    <span class="stat-num" style="color:var(--gold)">2030</span>
    <span class="stat-label" data-en="Unified Market Target" data-zh="全国统一市场目标">Unified Market Target</span>
  </div>
</div>

<!-- MAP SECTION -->
<div class="elec-section">
  <div class="section-header">
    <div class="section-icon">🗺</div>
    <div>
      <p class="section-title" data-en="Spot Price Distribution Map" data-zh="现货电价分布地图">Spot Price Distribution Map</p>
      <p class="section-subtitle" data-en="Hover a province to see market details" data-zh="悬停查看各省市场详情">Hover a province to see market details</p>
    </div>
  </div>
  <div class="map-wrap">
    <div class="map-header">
      <span class="map-title" data-en="Average Spot Electricity Price (¥/MWh) · 2024 Representative Data" data-zh="现货市场平均电价（元/MWh）· 2024年代表性数据">Average Spot Electricity Price (¥/MWh) · 2024 Representative Data</span>
      <span class="map-note lang-en">Click and drag to pan · Scroll to zoom</span>
      <span class="map-note lang-zh" style="display:none">拖动平移 · 滚轮缩放</span>
    </div>
    <div id="china-map"></div>
    <div class="map-legend">
      <div>
        <div class="legend-bar">
          <span class="lang-en" style="font-size:.72rem;color:var(--muted);white-space:nowrap">Low&nbsp;</span>
          <span class="lang-zh" style="display:none;font-size:.72rem;color:var(--muted);white-space:nowrap">低价&nbsp;</span>
          <div>
            <div class="legend-gradient"></div>
            <div class="legend-labels"><span>200</span><span>350</span><span>500+</span></div>
          </div>
          <span class="lang-en" style="font-size:.72rem;color:var(--muted);white-space:nowrap">&nbsp;High ¥/MWh</span>
          <span class="lang-zh" style="display:none;font-size:.72rem;color:var(--muted);white-space:nowrap">&nbsp;高价 元/MWh</span>
        </div>
      </div>
      <span style="font-size:.72rem;color:var(--muted)" class="lang-en">Grey = no spot market yet</span>
      <span style="font-size:.72rem;color:var(--muted);display:none" class="lang-zh">灰色 = 暂无现货市场</span>
    </div>
    <div class="map-disclaimer" data-en="⚠ Data shown are approximate representative averages for illustrative purposes. Actual spot prices vary hourly. Source: public market announcements, academic research." data-zh="⚠ 显示数据为说明性代表均值，非实时价格。实际现货电价每小时波动。来源：公开市场公告及学术研究。">⚠ Data shown are approximate representative averages for illustrative purposes. Actual spot prices vary hourly. Source: public market announcements, academic research.</div>
  </div>
</div>

<!-- PROVINCE CARDS -->
<div class="elec-section">
  <div class="section-header">
    <div class="section-icon">⚡</div>
    <div>
      <p class="section-title" data-en="Provincial Market Status" data-zh="各省市场状态">Provincial Market Status</p>
      <p class="section-subtitle" data-en="Filter by market status" data-zh="按市场状态筛选">Filter by market status</p>
    </div>
  </div>

  <div class="prov-tabs">
    <button class="prov-tab active" onclick="filterProvs('all')" data-en="All" data-zh="全部">All</button>
    <button class="prov-tab" onclick="filterProvs('formal')" data-en="● Formal Operation" data-zh="● 正式运行">● Formal Operation</button>
    <button class="prov-tab" onclick="filterProvs('trial')" data-en="● Trial" data-zh="● 模拟/试运行">● Trial</button>
    <button class="prov-tab" onclick="filterProvs('building')" data-en="● Building" data-zh="● 建设中">● Building</button>
  </div>

  <div class="prov-grid" id="prov-grid">
    <!-- generated by JS -->
  </div>
</div>

<!-- REFORM TIMELINE -->
<div class="elec-section" style="display:grid;grid-template-columns:1fr 1fr;gap:2.5rem">
  <div>
    <div class="section-header">
      <div class="section-icon">📅</div>
      <div><p class="section-title" data-en="Reform Timeline" data-zh="改革历程">Reform Timeline</p></div>
    </div>
    <div class="timeline-wrap">
      <div class="tl-item">
        <div class="tl-dot"></div>
        <div class="tl-year">2015</div>
        <div class="tl-text" data-en="Electricity system reform restarted — 'No.9 Document' issued" data-zh="电力体制改革重启 — 中发9号文颁布">Electricity system reform restarted — 'No.9 Document' issued</div>
      </div>
      <div class="tl-item">
        <div class="tl-dot"></div>
        <div class="tl-year">2017</div>
        <div class="tl-text" data-en="8 spot market pilot provinces announced (1st batch)" data-zh="8省市列为现货市场试点（第一批）">8 spot market pilot provinces announced (1st batch)</div>
        <div class="tl-sub" data-en="广东, 浙江, 山西, 蒙西, 四川, 甘肃, 福建, 山东" data-zh="广东、浙江、山西、蒙西、四川、甘肃、福建、山东">广东, 浙江, 山西, 蒙西, 四川, 甘肃, 福建, 山东</div>
      </div>
      <div class="tl-item">
        <div class="tl-dot"></div>
        <div class="tl-year">2019–2021</div>
        <div class="tl-text" data-en="First-batch pilots start trial and formal operation" data-zh="第一批试点陆续开展模拟试运行">First-batch pilots start trial and formal operation</div>
      </div>
      <div class="tl-item">
        <div class="tl-dot"></div>
        <div class="tl-year">2021</div>
        <div class="tl-text" data-en="6 more provinces in 2nd batch; Guangdong formally operational" data-zh="第二批新增6省；广东正式运行">6 more provinces in 2nd batch; Guangdong formally operational</div>
      </div>
      <div class="tl-item">
        <div class="tl-dot"></div>
        <div class="tl-year">2022</div>
        <div class="tl-text" data-en="NEA accelerates construction — 3rd batch expansion" data-zh="能源局加快推进，第三批扩围">NEA accelerates construction — 3rd batch expansion</div>
      </div>
      <div class="tl-item">
        <div class="tl-dot"></div>
        <div class="tl-year">2023</div>
        <div class="tl-text" data-en="Electricity Spot Market Basic Rules (Trial) issued nationally" data-zh="国家发布《电力现货市场基本规则（试行）》">Electricity Spot Market Basic Rules (Trial) issued nationally</div>
      </div>
      <div class="tl-item">
        <div class="tl-dot" style="border-color:var(--gold)"></div>
        <div class="tl-year" style="color:var(--gold)">2030 (Target)</div>
        <div class="tl-text" data-en="Nationally unified competitive electricity market" data-zh="全国统一电力市场体系基本建成">Nationally unified competitive electricity market</div>
      </div>
    </div>
  </div>

  <div>
    <div class="section-header">
      <div class="section-icon">📊</div>
      <div><p class="section-title" data-en="Market Structure" data-zh="市场结构">Market Structure</p></div>
    </div>
    <div id="structure-chart" style="height:320px"></div>
  </div>
</div>

<!-- POLICY DOCUMENTS -->
<div class="elec-section">
  <div class="section-header">
    <div class="section-icon">📄</div>
    <div>
      <p class="section-title" data-en="Policy Documents by Province" data-zh="各省政策文件">Policy Documents by Province</p>
      <p class="section-subtitle" data-en="Links to provincial government portals" data-zh="链接至各省政府门户">Links to provincial government portals</p>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem">
    <div>
      <!-- National -->
      <div class="docs-region">
        <div class="docs-region-title" data-en="National" data-zh="国家层面">National</div>
        <table class="docs-table">
          <tr><td class="dt-prov lang-en">NEA</td><td class="dt-prov lang-zh" style="display:none">能源局</td><td class="dt-doc lang-en"><em>Electricity Spot Market Basic Rules (Trial)</em> · 2023</td><td class="dt-doc lang-zh" style="display:none"><em>电力现货市场基本规则（试行）</em> · 2023</td><td class="dt-link"><a href="https://www.nea.gov.cn/2023-10/11/c_1310742773.htm" target="_blank">Link ↗</a></td></tr>
          <tr><td class="dt-prov lang-en">NEA</td><td class="dt-prov lang-zh" style="display:none">能源局</td><td class="dt-doc lang-en"><em>Notice on Accelerating Spot Market Construction</em> · 2022</td><td class="dt-doc lang-zh" style="display:none"><em>关于加快推进电力现货市场建设的通知</em> · 2022</td><td class="dt-link"><a href="https://www.nea.gov.cn/2022-10/28/c_1310669648.htm" target="_blank">Link ↗</a></td></tr>
          <tr><td class="dt-prov lang-en">NDRC</td><td class="dt-prov lang-zh" style="display:none">发改委</td><td class="dt-doc lang-en"><em>Electricity Market Operation Basic Rules</em> · 2022</td><td class="dt-doc lang-zh" style="display:none"><em>电力市场运行基本规则</em> · 2022</td><td class="dt-link"><a href="https://www.ndrc.gov.cn/xxgk/zcfb/ghxwj/202209/t20220907_1335432.html" target="_blank">Link ↗</a></td></tr>
        </table>
      </div>
      <!-- North + East -->
      <div class="docs-region">
        <div class="docs-region-title" data-en="North &amp; East China" data-zh="华北 &amp; 华东">North &amp; East China</div>
        <table class="docs-table">
          <tr><td class="dt-prov">山西</td><td class="dt-doc lang-en">Shanxi Spot Market Trial Rules</td><td class="dt-doc lang-zh" style="display:none">山西电力现货市场运营规则</td><td class="dt-link"><a href="http://nyj.shanxi.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">蒙西</td><td class="dt-doc lang-en">Inner Mongolia West Market Reform Plan</td><td class="dt-doc lang-zh" style="display:none">蒙西电力市场化改革方案</td><td class="dt-link"><a href="http://fgw.nmg.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">浙江</td><td class="dt-doc lang-en">Zhejiang Spot Market Trial Plan</td><td class="dt-doc lang-zh" style="display:none">浙江电力现货市场试点方案</td><td class="dt-link"><a href="https://fzggw.zj.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">山东</td><td class="dt-doc lang-en">Shandong Spot Market Operation Rules</td><td class="dt-doc lang-zh" style="display:none">山东电力现货市场运营规则</td><td class="dt-link"><a href="http://fgw.shandong.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">安徽</td><td class="dt-doc lang-en">Anhui Market Medium &amp; Long-term Rules</td><td class="dt-doc lang-zh" style="display:none">安徽电力市场中长期规则</td><td class="dt-link"><a href="http://fgw.ah.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">福建</td><td class="dt-doc lang-en">Fujian Spot Market Trial Rules</td><td class="dt-doc lang-zh" style="display:none">福建电力现货市场试运行规则</td><td class="dt-link"><a href="http://fgw.fujian.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">江苏</td><td class="dt-doc lang-en">Jiangsu Market Reform Plan</td><td class="dt-doc lang-zh" style="display:none">江苏电力体制改革试点方案</td><td class="dt-link"><a href="http://fgw.jiangsu.gov.cn" target="_blank">Portal ↗</a></td></tr>
        </table>
      </div>
    </div>
    <div>
      <!-- Central + South -->
      <div class="docs-region">
        <div class="docs-region-title" data-en="Central &amp; South China" data-zh="华中 &amp; 南方">Central &amp; South China</div>
        <table class="docs-table">
          <tr><td class="dt-prov">广东</td><td class="dt-doc lang-en">Guangdong Spot Market Official Rules</td><td class="dt-doc lang-zh" style="display:none">广东电力现货市场正式运行规则</td><td class="dt-link"><a href="http://drc.gd.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">湖北</td><td class="dt-doc lang-en">Hubei Market Reform Implementation Plan</td><td class="dt-doc lang-zh" style="display:none">湖北电力体制改革试点方案</td><td class="dt-link"><a href="http://fgw.hubei.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">湖南</td><td class="dt-doc lang-en">Hunan Market Medium &amp; Long-term Rules</td><td class="dt-doc lang-zh" style="display:none">湖南电力市场中长期交易规则</td><td class="dt-link"><a href="http://fgw.hunan.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">河南</td><td class="dt-doc lang-en">Henan Market Construction Plan</td><td class="dt-doc lang-zh" style="display:none">河南电力市场建设实施方案</td><td class="dt-link"><a href="http://fgw.henan.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">云南</td><td class="dt-doc lang-en">Yunnan Market Reform &amp; Trading Rules</td><td class="dt-doc lang-zh" style="display:none">云南电力市场中长期交易规则</td><td class="dt-link"><a href="http://fgw.yn.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">贵州</td><td class="dt-doc lang-en">Guizhou Market Medium &amp; Long-term Rules</td><td class="dt-doc lang-zh" style="display:none">贵州电力市场中长期交易规则</td><td class="dt-link"><a href="http://fgw.guizhou.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">广西</td><td class="dt-doc lang-en">Guangxi Market Construction Plan</td><td class="dt-doc lang-zh" style="display:none">广西电力市场建设运营方案</td><td class="dt-link"><a href="http://fgw.gxzf.gov.cn" target="_blank">Portal ↗</a></td></tr>
        </table>
      </div>
      <!-- Northwest + Southwest + Northeast -->
      <div class="docs-region">
        <div class="docs-region-title" data-en="Northwest / Southwest / Northeast" data-zh="西北 / 西南 / 东北">Northwest / Southwest / Northeast</div>
        <table class="docs-table">
          <tr><td class="dt-prov">陕西</td><td class="dt-doc lang-en">Shaanxi Spot Market Trial Rules</td><td class="dt-doc lang-zh" style="display:none">陕西电力现货市场试点规则</td><td class="dt-link"><a href="http://fgw.shaanxi.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">甘肃</td><td class="dt-doc lang-en">Gansu Spot Market Operation Rules</td><td class="dt-doc lang-zh" style="display:none">甘肃电力现货市场运营规则</td><td class="dt-link"><a href="http://fgw.gansu.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">宁夏</td><td class="dt-doc lang-en">Ningxia Market Construction Plan</td><td class="dt-doc lang-zh" style="display:none">宁夏电力市场建设方案</td><td class="dt-link"><a href="http://fgw.nx.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">新疆</td><td class="dt-doc lang-en">Xinjiang Market Medium &amp; Long-term Rules</td><td class="dt-doc lang-zh" style="display:none">新疆电力市场中长期交易规则</td><td class="dt-link"><a href="http://www.xjdrc.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">四川</td><td class="dt-doc lang-en">Sichuan Spot Market Trial Rules</td><td class="dt-doc lang-zh" style="display:none">四川电力现货市场试运行规则</td><td class="dt-link"><a href="https://fgw.sc.gov.cn" target="_blank">Portal ↗</a></td></tr>
          <tr><td class="dt-prov">辽宁</td><td class="dt-doc lang-en">Liaoning Market Reform Rules</td><td class="dt-doc lang-zh" style="display:none">辽宁电力市场化改革规则</td><td class="dt-link"><a href="http://fgw.ln.gov.cn" target="_blank">Portal ↗</a></td></tr>
        </table>
      </div>
    </div>
  </div>
</div>

<div class="elec-footer">
  <p data-en="© 2025 Yugang Yang · Renmin University of China · School of Applied Economics · Data for research illustration only" data-zh="© 2025 杨玉刚 · 中国人民大学应用经济学院 · 数据仅供研究说明">
    © 2025 Yugang Yang · Renmin University of China · School of Applied Economics · Data for research illustration only
  </p>
</div>

<!-- ECharts -->
<script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
<script>
// ===== PROVINCE DATA =====
const provData = [
  // Formal operation
  {name:'广东', nameEn:'Guangdong', value:530, status:'formal', year:2021, region:'South'},
  {name:'浙江', nameEn:'Zhejiang',  value:445, status:'formal', year:2021, region:'East'},
  {name:'山西', nameEn:'Shanxi',    value:315, status:'formal', year:2020, region:'North'},
  {name:'内蒙古', nameEn:'Inner Mongolia', value:245, status:'formal', year:2019, region:'North'},
  {name:'甘肃', nameEn:'Gansu',    value:238, status:'formal', year:2019, region:'Northwest'},
  {name:'山东', nameEn:'Shandong', value:395, status:'formal', year:2022, region:'East'},
  {name:'四川', nameEn:'Sichuan',  value:285, status:'formal', year:2022, region:'Southwest'},
  {name:'福建', nameEn:'Fujian',   value:442, status:'formal', year:2022, region:'East'},
  {name:'云南', nameEn:'Yunnan',   value:228, status:'formal', year:2022, region:'South'},
  {name:'广西', nameEn:'Guangxi',  value:352, status:'formal', year:2022, region:'South'},
  {name:'贵州', nameEn:'Guizhou',  value:278, status:'formal', year:2022, region:'South'},
  // Trial
  {name:'湖北', nameEn:'Hubei',    value:382, status:'trial',  year:2022, region:'Central'},
  {name:'湖南', nameEn:'Hunan',    value:368, status:'trial',  year:2023, region:'Central'},
  {name:'河南', nameEn:'Henan',    value:375, status:'trial',  year:2023, region:'Central'},
  {name:'安徽', nameEn:'Anhui',    value:412, status:'trial',  year:2023, region:'East'},
  {name:'江苏', nameEn:'Jiangsu',  value:452, status:'trial',  year:2023, region:'East'},
  {name:'陕西', nameEn:'Shaanxi',  value:342, status:'trial',  year:2022, region:'Northwest'},
  {name:'宁夏', nameEn:'Ningxia',  value:255, status:'trial',  year:2022, region:'Northwest'},
  {name:'辽宁', nameEn:'Liaoning', value:358, status:'trial',  year:2023, region:'Northeast'},
  {name:'重庆', nameEn:'Chongqing',value:298, status:'trial',  year:2023, region:'Southwest'},
  {name:'新疆', nameEn:'Xinjiang', value:225, status:'trial',  year:2023, region:'Northwest'},
  // Building
  {name:'黑龙江', nameEn:'Heilongjiang', value:null, status:'building', year:null, region:'Northeast'},
  {name:'吉林',   nameEn:'Jilin',        value:null, status:'building', year:null, region:'Northeast'},
  {name:'河北',   nameEn:'Hebei',        value:null, status:'building', year:null, region:'North'},
  {name:'江西',   nameEn:'Jiangxi',      value:null, status:'building', year:null, region:'Central'},
  {name:'青海',   nameEn:'Qinghai',      value:215, status:'building',  year:null, region:'Northwest'},
  // No market yet
  {name:'北京',   nameEn:'Beijing',  value:null, status:'na', year:null, region:'North'},
  {name:'天津',   nameEn:'Tianjin',  value:null, status:'na', year:null, region:'North'},
  {name:'上海',   nameEn:'Shanghai', value:null, status:'na', year:null, region:'East'},
  {name:'海南',   nameEn:'Hainan',   value:null, status:'na', year:null, region:'South'},
  {name:'西藏',   nameEn:'Tibet',    value:null, status:'na', year:null, region:'Southwest'},
];

const statusLabel = { formal:'Formal', trial:'Trial', building:'Building', na:'No Market' };
const statusLabelZh = { formal:'正式运行', trial:'模拟/试运行', building:'建设中', na:'暂无市场' };

// ===== RENDER PROVINCE CARDS =====
function renderCards(filter) {
  const lang = document.documentElement.lang === 'zh-CN' ? 'zh' : 'en';
  const grid = document.getElementById('prov-grid');
  const data = filter === 'all' ? provData : provData.filter(p => p.status === filter);
  grid.innerHTML = data.map(p => {
    const priceClass = p.value === null ? 'price-na' : p.value >= 450 ? 'price-high' : p.value >= 330 ? 'price-medium' : 'price-low';
    const priceDisplay = p.value === null ? 'N/A' : p.value;
    const unit = p.value !== null ? (lang === 'zh' ? '<span class="prov-unit">元/MWh · 代表均值</span>' : '<span class="prov-unit">¥/MWh · avg</span>') : '';
    const label = lang === 'zh' ? statusLabelZh[p.status] : statusLabel[p.status];
    const yearStr = p.year ? `<span class="prov-unit">${lang === 'zh' ? '入市' : 'Since'} ${p.year}</span>` : '';
    return `<div class="prov-card status-${p.status}">
      <div class="prov-name">${p.name} <span class="prov-name-en">${p.nameEn}</span></div>
      <div class="prov-price ${priceClass}">${priceDisplay}</div>
      <div class="prov-meta">
        ${unit || yearStr}
        <span class="status-badge badge-${p.status}">${label}</span>
      </div>
    </div>`;
  }).join('');
}

function filterProvs(f) {
  document.querySelectorAll('.prov-tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  renderCards(f);
}

// ===== MAP =====
let myChart;
function initMap(geoJson) {
  echarts.registerMap('china', geoJson);
  myChart = echarts.init(document.getElementById('china-map'), null, { renderer: 'svg' });

  const mapData = provData.filter(p => p.value !== null).map(p => ({
    name: p.name, value: p.value, status: p.status, year: p.year
  }));

  const option = {
    backgroundColor: 'transparent',
    tooltip: {
      trigger: 'item',
      backgroundColor: 'rgba(13,27,42,.95)',
      borderColor: 'rgba(0,212,170,.3)',
      textStyle: { color: '#e0eaf5', fontSize: 12 },
      formatter: p => {
        const d = provData.find(x => x.name === p.name);
        if (!d) return `<b>${p.name}</b><br/>No market data`;
        const lang = document.documentElement.lang === 'zh-CN' ? 'zh' : 'en';
        const sl = lang === 'zh' ? statusLabelZh[d.status] : statusLabel[d.status];
        const yr = d.year ? (lang === 'zh' ? `<br/>入市：${d.year}年` : `<br/>Launch: ${d.year}`) : '';
        const pr = d.value ? `<br/><span style="color:#00d4aa;font-weight:700;font-size:15px">${d.value}</span> ¥/MWh` : '';
        return `<b style="font-size:13px">${p.name}</b>${pr}<br/><span style="color:#8899aa">${sl}</span>${yr}`;
      }
    },
    visualMap: {
      min: 200, max: 540,
      left: 20, bottom: 40,
      orient: 'vertical',
      itemWidth: 14, itemHeight: 120,
      textStyle: { color: '#8899aa', fontSize: 11 },
      text: ['540 ¥/MWh', '200 ¥/MWh'],
      inRange: { color: ['#1a3a72','#1565c0','#0097a7','#f9a825','#e64a19'] },
      outOfRange: { color: ['#1e2d3d'] },
    },
    series: [{
      name: 'Spot Price',
      type: 'map',
      map: 'china',
      roam: true,
      scaleLimit: { min: 0.8, max: 4 },
      label: {
        show: true,
        fontSize: 9,
        color: 'rgba(224,234,245,.7)',
        formatter: p => {
          const d = provData.find(x => x.name === p.name);
          return d && d.value ? `${p.name}\n${d.value}` : p.name;
        }
      },
      itemStyle: {
        areaColor: '#1e2d3d',
        borderColor: 'rgba(0,212,170,.2)',
        borderWidth: 0.5,
      },
      emphasis: {
        label: { color: '#fff', fontSize: 10 },
        itemStyle: { areaColor: 'rgba(0,212,170,.25)', borderColor: '#00d4aa', borderWidth: 1.5 }
      },
      data: mapData,
    }]
  };
  myChart.setOption(option);
  window.addEventListener('resize', () => myChart.resize());
}

// ===== DONUT CHART (market structure) =====
function initDonut() {
  const chart = echarts.init(document.getElementById('structure-chart'), null, {renderer:'svg'});
  const lang = document.documentElement.lang === 'zh-CN' ? 'zh' : 'en';
  chart.setOption({
    backgroundColor: 'transparent',
    tooltip: { trigger: 'item', backgroundColor:'rgba(13,27,42,.95)', borderColor:'rgba(0,212,170,.3)', textStyle:{color:'#e0eaf5'} },
    legend: { bottom: 10, textStyle: { color:'#8899aa', fontSize:11 }, orient:'horizontal' },
    series: [{
      type: 'pie', radius: ['42%','68%'], center:['50%','44%'],
      avoidLabelOverlap: true,
      itemStyle: { borderRadius: 5, borderColor:'#0d1b2a', borderWidth:2 },
      label: { show: true, formatter: '{b}\n{c}', color:'#8899aa', fontSize:10 },
      emphasis: { label:{show:true, fontSize:12, color:'#e0eaf5'} },
      data: [
        {value:11, name: lang==='zh'?'正式运行':'Formal',   itemStyle:{color:'#00d4aa'}},
        {value:10, name: lang==='zh'?'试运行':'Trial',      itemStyle:{color:'#f0a500'}},
        {value: 5, name: lang==='zh'?'建设中':'Building',   itemStyle:{color:'#3b9eff'}},
        {value: 8, name: lang==='zh'?'暂无市场':'No Market', itemStyle:{color:'#2d3f52'}},
      ]
    }]
  });
  window.addEventListener('resize', () => chart.resize());
}

// ===== i18n =====
function setLang(lang) {
  localStorage.setItem('lang', lang);
  document.documentElement.lang = lang === 'zh' ? 'zh-CN' : 'en';
  document.querySelectorAll('.lang-en').forEach(el => el.style.display = lang==='en' ? '' : 'none');
  document.querySelectorAll('.lang-zh').forEach(el => el.style.display = lang==='zh' ? '' : 'none');
  document.querySelectorAll('[data-en]').forEach(el => { el.textContent = lang==='en' ? el.dataset.en : el.dataset.zh; });
  document.getElementById('hbtn-en').classList.toggle('active', lang==='en');
  document.getElementById('hbtn-zh').classList.toggle('active', lang==='zh');
  renderCards('all');
  document.querySelectorAll('.prov-tab')[0].click();
}

// ===== INIT =====
const savedLang = localStorage.getItem('lang') || 'en';
document.documentElement.lang = savedLang === 'zh' ? 'zh-CN' : 'en';
document.getElementById('hbtn-en').classList.toggle('active', savedLang==='en');
document.getElementById('hbtn-zh').classList.toggle('active', savedLang==='zh');
if (savedLang === 'zh') {
  document.querySelectorAll('.lang-en').forEach(el => el.style.display='none');
  document.querySelectorAll('.lang-zh').forEach(el => el.style.display='');
  document.querySelectorAll('[data-en]').forEach(el => el.textContent = el.dataset.zh);
}
renderCards('all');
initDonut();

// Load China GeoJSON from DataV (Alibaba Cloud)
fetch('https://geo.datav.aliyun.com/areas_v3/bound/100000_full.json')
  .then(r => r.json())
  .then(geoJson => initMap(geoJson))
  .catch(() => {
    // Fallback: try jsdelivr
    fetch('https://cdn.jsdelivr.net/npm/echarts@5.4.3/map/json/china.json')
      .then(r => r.json())
      .then(geoJson => initMap(geoJson))
      .catch(() => {
        document.getElementById('china-map').innerHTML = '<p style="text-align:center;padding:4rem;color:#8899aa">Map unavailable offline. Connect to internet to load province boundaries.</p>';
      });
  });
</script>
</body>
</html>
