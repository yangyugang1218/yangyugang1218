/* ============================================================
   YUGANG YANG — ACADEMIC WEBSITE  (Two-column sidebar layout)
   ============================================================ */

:root {
  --accent:      #2e7d32;
  --accent-lt:   #e8f5e9;
  --primary:     #1a1a2e;
  --text:        #1a1a2e;
  --text-muted:  #6b7280;
  --border:      #e5e7eb;
  --bg:          #ffffff;
  --sidebar-bg:  #fafafa;
  --nav-h:       52px;
  --sidebar-w:   230px;
  --radius:      6px;
  --transition:  .2s ease;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 14px;
  color: var(--text);
  background: var(--bg);
  line-height: 1.65;
}
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }
ul, ol { list-style: none; }
strong { font-weight: 600; }

/* ===== NAV ===== */
#navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  height: var(--nav-h);
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  transition: box-shadow var(--transition);
}
#navbar.scrolled { box-shadow: 0 1px 8px rgba(0,0,0,.07); }
.nav-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.25rem;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 1rem;
}
.nav-brand {
  font-size: .95rem;
  font-weight: 700;
  color: var(--text);
  white-space: nowrap;
  letter-spacing: -.2px;
  flex-shrink: 0;
}
.nav-tabs {
  display: flex;
  gap: .1rem;
  flex: 1;
  overflow: hidden;
}
.nav-tabs a {
  padding: .3rem .7rem;
  border-radius: var(--radius);
  font-size: .82rem;
  font-weight: 500;
  color: var(--text-muted);
  white-space: nowrap;
  transition: color var(--transition), background var(--transition);
}
.nav-tabs a:hover,
.nav-tabs a.active { color: var(--text); background: #f3f4f6; text-decoration: none; }
.nav-tabs a.active { font-weight: 600; }

.nav-right { display: flex; align-items: center; gap: .6rem; flex-shrink: 0; }
.lang-switcher { display: flex; gap: .25rem; }
.lang-btn {
  background: none;
  border: 1px solid var(--border);
  border-radius: 5px;
  padding: .2rem .55rem;
  font-size: .75rem;
  font-weight: 600;
  cursor: pointer;
  color: var(--text-muted);
  transition: all var(--transition);
}
.lang-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }
.lang-btn:hover:not(.active) { border-color: var(--accent); color: var(--accent); }
.hamburger { display: none; background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-muted); }

/* ===== LAYOUT ===== */
.layout {
  display: flex;
  margin-top: var(--nav-h);
  min-height: calc(100vh - var(--nav-h));
  max-width: 1200px;
  margin-left: auto;
  margin-right: auto;
}

/* ===== SIDEBAR ===== */
.sidebar {
  width: var(--sidebar-w);
  flex-shrink: 0;
  background: var(--sidebar-bg);
  border-right: 1px solid var(--border);
  position: sticky;
  top: var(--nav-h);
  height: calc(100vh - var(--nav-h));
  overflow-y: auto;
  padding: 1.75rem 1.25rem 2rem;
  scrollbar-width: thin;
}
.profile-wrap { text-align: center; padding-bottom: 1.25rem; border-bottom: 1px solid var(--border); margin-bottom: 1.25rem; }
.profile-photo {
  width: 130px; height: 155px;
  border-radius: 8px;
  object-fit: cover;
  object-position: 50% 22%;
  border: 2px solid var(--border);
  display: block;
  margin: 0 auto .9rem;
}
.profile-name  { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: .2rem; }
.profile-title { font-size: .8rem; font-weight: 600; color: var(--accent); margin-bottom: .1rem; }
.profile-dept  { font-size: .78rem; color: var(--text-muted); margin-bottom: .35rem; }
.profile-affil { font-size: .76rem; color: var(--text-muted); line-height: 1.5; }

.sidebar-links { display: flex; flex-direction: column; gap: .4rem; margin-bottom: 1.25rem; }
.slink {
  display: flex;
  align-items: center;
  gap: .45rem;
  font-size: .76rem;
  color: var(--text-muted);
  padding: .3rem .4rem;
  border-radius: 5px;
  transition: background var(--transition), color var(--transition);
  word-break: break-all;
}
.slink svg { width: 13px; height: 13px; flex-shrink: 0; }
.slink:hover { background: #f0f0f0; color: var(--text); text-decoration: none; }
.cv-link {
  background: var(--accent);
  color: #fff !important;
  justify-content: center;
  font-weight: 600;
  border-radius: 5px;
  margin-top: .25rem;
}
.cv-link:hover { background: #1b5e20 !important; }

.sidebar-section { margin-bottom: 1.25rem; }
.sidebar-heading {
  font-size: .7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .8px;
  color: var(--text-muted);
  margin-bottom: .55rem;
}
.interest-list { display: flex; flex-direction: column; gap: .25rem; }
.interest-list li {
  font-size: .78rem;
  color: var(--text);
  padding: .2rem 0 .2rem .65rem;
  border-left: 2px solid var(--accent);
  line-height: 1.4;
}
.skills-text { font-size: .78rem; color: var(--text-muted); line-height: 1.7; }

/* ===== MAIN CONTENT ===== */
.content {
  flex: 1;
  min-width: 0;
  padding: 2.25rem 2.75rem 3rem;
}

/* Sections */
section { scroll-margin-top: calc(var(--nav-h) + 12px); }
.sec-title {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: .9rem;
  padding-bottom: .5rem;
  border-bottom: 2px solid var(--accent);
  display: inline-block;
}
.sec-note { font-size: .78rem; color: var(--text-muted); margin-bottom: .9rem; }
.divider { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

/* About */
.about-text { font-size: .9rem; line-height: 1.75; color: var(--text); max-width: 680px; margin-bottom: 1.25rem; }

/* News */
.news-box { background: #f9fafb; border: 1px solid var(--border); border-radius: var(--radius); padding: .9rem 1.1rem; max-width: 680px; }
.news-title { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .7px; color: var(--text-muted); margin-bottom: .65rem; }
.news-list { display: flex; flex-direction: column; gap: .5rem; }
.news-item { display: flex; gap: .75rem; align-items: flex-start; font-size: .83rem; }
.news-date { flex-shrink: 0; font-size: .75rem; font-weight: 600; color: var(--accent); padding-top: .05rem; min-width: 54px; }

/* Education */
.edu-entry {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  padding: .7rem 0;
  border-bottom: 1px solid #f0f0f0;
}
.edu-entry:last-child { border-bottom: none; }
.edu-school { font-size: .9rem; font-weight: 600; color: var(--text); margin-bottom: .15rem; }
.edu-degree { font-size: .85rem; color: var(--text); margin-bottom: .15rem; }
.edu-tag {
  display: inline-block;
  font-size: .7rem; font-weight: 500;
  background: var(--accent-lt); color: var(--accent);
  padding: .1rem .45rem; border-radius: 4px; margin-left: .3rem;
  vertical-align: middle;
}
.edu-meta { font-size: .78rem; color: var(--text-muted); }
.edu-date { font-size: .78rem; color: var(--text-muted); white-space: nowrap; flex-shrink: 0; padding-top: .15rem; }

/* Publications */
.pub-group-title {
  font-size: .72rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: .8px;
  color: var(--text-muted); margin-bottom: .65rem;
}
.pub-list { display: flex; flex-direction: column; }
.pub-entry {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  padding: .65rem 0;
  border-bottom: 1px solid #f0f0f0;
}
.pub-entry:last-child { border-bottom: none; }
.pub-main { flex: 1; min-width: 0; }
.pub-title { font-size: .87rem; font-weight: 500; color: var(--text); line-height: 1.5; margin-bottom: .25rem; }
.pub-meta  { font-size: .78rem; color: var(--text-muted); line-height: 1.5; }
.pub-doi {
  flex-shrink: 0;
  font-size: .72rem; font-weight: 600;
  color: var(--accent); border: 1px solid var(--accent);
  padding: .18rem .5rem; border-radius: 4px;
  white-space: nowrap; height: fit-content;
  transition: background var(--transition), color var(--transition);
}
.pub-doi:hover { background: var(--accent); color: #fff; text-decoration: none; }

.tag-journal {
  display: inline-block; font-size: .7rem; font-weight: 500;
  background: #e3f2fd; color: #1565c0;
  padding: .08rem .4rem; border-radius: 3px;
}
.tag-role {
  display: inline-block; font-size: .7rem; font-weight: 500;
  padding: .08rem .4rem; border-radius: 3px;
}
.tag-corr { background: var(--accent-lt); color: var(--accent); }
.tag-main { background: #fff3e0; color: #e65100; }

/* Projects */
.proj-list { display: flex; flex-direction: column; gap: .6rem; }
.proj-entry {
  display: flex; gap: .85rem; align-items: flex-start;
  padding: .6rem 0; border-bottom: 1px solid #f0f0f0;
}
.proj-entry:last-child { border-bottom: none; }
.proj-num {
  flex-shrink: 0;
  font-size: .7rem; font-weight: 700;
  background: var(--primary); color: #fff;
  padding: .2rem .5rem; border-radius: 4px;
  white-space: nowrap; height: fit-content; margin-top: .1rem;
}
.proj-title-text { font-size: .87rem; font-weight: 500; color: var(--text); margin-bottom: .15rem; line-height: 1.5; }
.proj-meta { font-size: .77rem; color: var(--text-muted); }

/* Reports table */
.report-table { width: 100%; border-collapse: collapse; font-size: .84rem; }
.report-table tr { border-bottom: 1px solid #f0f0f0; }
.report-table tr:last-child { border-bottom: none; }
.report-table td { padding: .5rem .4rem .5rem 0; vertical-align: top; }
.rt-year { width: 44px; color: var(--accent); font-weight: 700; font-size: .76rem; padding-top: .55rem; white-space: nowrap; }
.rt-org { color: var(--text-muted); font-size: .78rem; }

/* Electricity Market */
.elec-group { margin-bottom: 1.5rem; }
.elec-region-label {
  font-size: .72rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: .7px;
  color: var(--text-muted);
  margin-bottom: .5rem;
  display: flex; align-items: center; gap: .4rem;
}
.elec-region-sub { font-size: .7rem; color: #bbb; text-transform: none; font-weight: 400; letter-spacing: 0; }
.elec-table { width: 100%; border-collapse: collapse; font-size: .82rem; }
.elec-table tr { border-bottom: 1px solid #f0f0f0; }
.elec-table tr:last-child { border-bottom: none; }
.elec-table td { padding: .45rem .4rem .45rem 0; vertical-align: top; }
.elec-prov-cell {
  width: 52px; font-weight: 700; font-size: .8rem; color: var(--primary);
  white-space: nowrap; padding-top: .5rem;
}
.elec-link {
  display: inline-block;
  font-size: .71rem; font-weight: 600;
  color: var(--accent); border: 1px solid var(--accent);
  padding: .15rem .45rem; border-radius: 4px; white-space: nowrap;
  transition: background var(--transition), color var(--transition);
}
.elec-link:hover { background: var(--accent); color: #fff; text-decoration: none; }

/* Awards */
.award-table { width: 100%; border-collapse: collapse; font-size: .84rem; max-width: 560px; }
.award-table tr { border-bottom: 1px solid #f0f0f0; }
.award-table tr:last-child { border-bottom: none; }
.award-table td { padding: .45rem .4rem .45rem 0; }
.award-note { color: var(--text-muted); font-size: .78rem; text-align: right; white-space: nowrap; padding-left: 1rem; }

/* Footer */
footer {
  margin-top: 3rem;
  padding-top: 1.25rem;
  border-top: 1px solid var(--border);
  font-size: .77rem;
  color: var(--text-muted);
}
footer a { color: var(--text-muted); }
footer a:hover { color: var(--accent); }

/* Stats Row */
.stats-row { display: flex; gap: .75rem; flex-wrap: wrap; margin: 1.25rem 0 1.5rem; }
.stat-item { text-align: center; padding: .5rem .85rem; background: var(--accent-lt); border-radius: 8px; flex: 1; min-width: 70px; max-width: 130px; }
.stat-num { display: block; font-size: 1.3rem; font-weight: 700; color: var(--accent); line-height: 1.2; }
.stat-label { display: block; font-size: .7rem; color: var(--text-muted); margin-top: .1rem; white-space: nowrap; }

/* Journal covers */
.pub-cover {
  flex-shrink: 0;
  width: 44px; height: 58px;
  border-radius: 4px;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  font-size: .58rem; font-weight: 700; text-align: center; line-height: 1.3;
  color: #fff; padding: 3px;
  margin-top: .05rem;
}
.cover-ep   { background: linear-gradient(160deg, #1b5e20, #388e3c); }
.cover-ee   { background: linear-gradient(160deg, #0d47a1, #1976d2); }
.cover-ehb  { background: linear-gradient(160deg, #006064, #00838f); }
.cover-hgjj { background: linear-gradient(160deg, #880e4f, #c2185b); }
.cover-gjjr { background: linear-gradient(160deg, #bf360c, #f4511e); }

/* Electricity Feature Banner */
.elec-banner {
  display: block;
  background: linear-gradient(135deg, #0d1b2a 0%, #1a2f4a 60%, #0d2137 100%);
  border-radius: 10px;
  padding: 1.4rem 1.75rem;
  margin-top: .75rem;
  position: relative; overflow: hidden;
  border: 1px solid rgba(0,180,200,.2);
  color: #e0f7fa;
  transition: border-color var(--transition), box-shadow var(--transition);
}
.elec-banner:hover { border-color: rgba(0,180,200,.55); box-shadow: 0 4px 22px rgba(0,180,200,.1); text-decoration: none; }
.elec-banner::before {
  content: ''; position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(circle at 80% 50%, rgba(0,180,200,.09) 0%, transparent 55%);
}
.elec-banner-inner { display: flex; align-items: center; gap: 1.25rem; position: relative; z-index: 1; }
.elec-banner-icon {
  flex-shrink: 0;
  width: 58px; height: 58px; border-radius: 12px;
  background: rgba(0,180,200,.13); border: 1px solid rgba(0,180,200,.28);
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem;
}
.elec-banner-body { flex: 1; min-width: 0; }
.elec-banner-title { font-size: .93rem; font-weight: 700; color: #e0f7fa; margin-bottom: .28rem; }
.elec-banner-desc { font-size: .79rem; color: rgba(200,235,245,.7); margin-bottom: .55rem; line-height: 1.55; }
.elec-banner-tags { display: flex; flex-wrap: wrap; gap: .32rem; }
.elec-banner-tag {
  font-size: .67rem; font-weight: 600;
  background: rgba(0,180,200,.1); color: #80deea;
  border: 1px solid rgba(0,180,200,.25); border-radius: 4px;
  padding: .1rem .42rem;
}
.elec-banner-btn {
  flex-shrink: 0;
  background: linear-gradient(135deg, #00b4d8, #0077b6);
  color: #fff; font-weight: 700; font-size: .8rem;
  padding: .55rem 1rem; border-radius: 7px; white-space: nowrap;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 960px) {
  .sidebar { width: 200px; }
  .content { padding: 1.75rem 2rem 2.5rem; }
}

@media (max-width: 768px) {
  .layout { flex-direction: column; margin-top: var(--nav-h); }
  .sidebar {
    width: 100%;
    position: static;
    height: auto;
    border-right: none;
    border-bottom: 1px solid var(--border);
    padding: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .profile-wrap { border-bottom: none; margin-bottom: 0; padding-bottom: 0; text-align: left; display: flex; gap: 1rem; align-items: flex-start; flex-shrink: 0; }
  .profile-photo { width: 80px; height: 96px; margin: 0; }
  .sidebar-links, .sidebar-section { flex: 1; min-width: 160px; }
  .content { padding: 1.5rem 1.25rem 2rem; }
  .nav-tabs {
    display: none;
    flex-direction: column;
    position: fixed;
    top: var(--nav-h); left: 0; right: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: .75rem 1rem;
    gap: .2rem;
    box-shadow: 0 6px 16px rgba(0,0,0,.08);
    z-index: 199;
  }
  .nav-tabs.open { display: flex; }
  .hamburger { display: block; }
}

@media (max-width: 480px) {
  .content { padding: 1.25rem 1rem 1.5rem; }
  .pub-entry { flex-direction: column; }
  .pub-doi { align-self: flex-start; }
  .edu-entry { flex-direction: column; gap: .2rem; }
  .profile-wrap { flex-direction: column; align-items: center; text-align: center; }
}
